{
  "expo": {
    "name": "baja-valle-app",
    "slug": "baja-valle-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "bajavalleapp",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/expo.icon"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#512432",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 200
          },
          "ios": {
            "image": "./assets/images/splash-icon.png"
          }
        }
      ],
      [
        "expo-font",
        {
          "fonts": [
            "node_modules/@expo-google-fonts/montserrat/Montserrat-Thin.ttf",
            "node_modules/@expo-google-fonts/montserrat/Montserrat-ExtraLight.ttf",
            "node_modules/@expo-google-fonts/montserrat/Montserrat-Light.ttf",
            "node_modules/@expo-google-fonts/montserrat/Montserrat-Regular.ttf",
            "node_modules/@expo-google-fonts/montserrat/Montserrat-Medium.ttf",
            "node_modules/@expo-google-fonts/montserrat/Montserrat-SemiBold.ttf",
            "node_modules/@expo-google-fonts/montserrat/Montserrat-Bold.ttf",
            "node_modules/@expo-google-fonts/montserrat/Montserrat-ExtraBold.ttf",
            "node_modules/@expo-google-fonts/montserrat/Montserrat-Black.ttf"
          ]
        }
      ],
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
